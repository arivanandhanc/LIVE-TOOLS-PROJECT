# ─────────────── ConvertFlow frontend env ───────────────
# Copy to .env.local and fill in. Only NEXT_PUBLIC_* vars reach the browser.

# Public site URL (used for canonical URLs, sitemap, OG tags)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Backend API origin (also allowlisted in the CSP connect-src)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Google reCAPTCHA v3 — SITE key only (this one is public/safe to ship).
# The matching SECRET key belongs in the SERVER env, never here.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
