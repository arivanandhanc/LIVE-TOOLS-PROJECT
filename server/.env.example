# ─────────────── ConvertFlow server env ───────────────
# Copy to .env and fill in. The app runs with ALL of these unset (guest mode,
# local-disk storage, in-memory queue) — set them to enable each capability.

NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000

# Comma-separated allowlist of front-end origins (CORS)
CORS_ORIGINS=http://localhost:3000

# ── Persistence (optional) ──
# PostgreSQL (Neon recommended). Leave empty for guest-only mode.
DATABASE_URL=
# Redis (Upstash) — enables BullMQ queue + distributed rate limiting.
REDIS_URL=

# ── Storage ──
# local | s3   (s3 also covers Cloudflare R2 / MinIO)
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=./storage
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

# ── Auth ──
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# ── Google reCAPTCHA v3 (SECRET key — server only, never commit real value) ──
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5
RECAPTCHA_ENABLED=false

# ── File handling / retention ──
MAX_UPLOAD_BYTES=52428800
MAX_FILES_PER_REQUEST=20
GUEST_RETENTION_MS=3600000
USER_RETENTION_MS=86400000

# ── Rate limiting ──
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
UPLOAD_RATE_LIMIT_MAX=40

LOG_LEVEL=debug
