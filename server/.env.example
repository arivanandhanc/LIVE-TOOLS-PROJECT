# ConvertFlow API — environment template. Copy to .env and fill in.
# Everything is optional except in production; absence => graceful degradation.

NODE_ENV=development
PORT=4000

# Public origin of THIS API (used to build download URLs + OAuth redirect URIs).
# On Render this auto-derives from RENDER_EXTERNAL_URL if omitted.
API_BASE_URL=http://localhost:4000

# Comma-separated allowlist of web-app origins for CORS (credentials enabled).
CORS_ORIGINS=http://localhost:3000

# Where the API sends users back after OAuth (defaults to first CORS origin).
WEB_APP_URL=http://localhost:3000

# ── Persistence (optional locally; required for accounts/usage/OTP) ──
# Postgres connection string (e.g. Neon). Without it the app is guest-only:
# no accounts, dashboard stats, favorites, OTP, or Google sign-in.
DATABASE_URL=
# REDIS_URL=

# ── Storage: "local" (disk) or "s3" (S3/R2-compatible) ──
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=./storage
# S3_ENDPOINT=
# S3_REGION=auto
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_URL=

# ── Auth ──
JWT_SECRET=change-me-to-a-long-random-string
# JWT_ACCESS_TTL=15m
# JWT_REFRESH_TTL_DAYS=30

# ── Google sign-in (optional). When both are set, the Google button activates. ──
# Authorized redirect URI in Google Cloud console must be:
#   <API_BASE_URL>/api/auth/oauth/google/callback
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# ── Email / OTP (optional). Without SMTP, OTP codes are logged to the server
# console (dev) instead of emailed. Set these to actually deliver codes. ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ConvertFlow <no-reply@arivanandhan.in>

# ── AI tools (optional). When set, the AI category goes live. ──
ANTHROPIC_API_KEY=
# Model id (defaults to claude-opus-4-8). Use claude-sonnet-4-6 for lower cost.
AI_MODEL=claude-opus-4-8

# ── Google reCAPTCHA v3 (secret stays server-side) ──
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5
RECAPTCHA_ENABLED=false

# ── Misc ──
# MAX_UPLOAD_BYTES=52428800
LOG_LEVEL=debug
